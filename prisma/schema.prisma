generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model AdminProfile {
  id           String   @id @default(uuid())
  userId       String   @unique(map: "AdminProfile_userId_key")
  isSuperAdmin Boolean  @default(false)
  filiereId    String?
  filiere      Filiere? @relation(fields: [filiereId], references: [id])
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([filiereId], map: "AdminProfile_filiereId_idx")
  @@map("adminprofile")
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String
  action     String
  targetType String
  targetId   String
  details    String?  @db.LongText
  ipAddress  String?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "AuditLog_userId_idx")
  @@map("auditlog")
}

model BlockedEmail {
  id        String   @id @default(uuid())
  email     String   @unique(map: "BlockedEmail_email_key")
  reason    String?  @db.Text
  createdAt DateTime @default(now())

  @@map("blockedemail")
}

model TeamInvitation {
  id               String                @id @default(uuid())
  teamId           String
  invitedStudentId String
  status           teaminvitation_status @default(PENDING)
  message          String?               @db.Text
  responseComment  String?               @db.Text
  respondedAt      DateTime?
  expiresAt        DateTime
  createdAt        DateTime              @default(now())
  user             User                  @relation(fields: [invitedStudentId], references: [id], onDelete: Cascade)
  studentteam      StudentTeam           @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([teamId], map: "TeamInvitation_teamId_idx")
  @@index([invitedStudentId], map: "TeamInvitation_invitedStudentId_idx")
  @@index([status], map: "TeamInvitation_status_idx")
  @@map("teaminvitation")
}

model StudentTeam {
  id                 String               @id @default(uuid())
  leaderId           String
  filiereId          String?
  academicYear       String
  reason             String?              @db.Text
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  studentapplication StudentApplication[]
  filiere            Filiere?             @relation(fields: [filiereId], references: [id])
  user               User                 @relation(fields: [leaderId], references: [id], onDelete: Cascade)
  teaminvitation     TeamInvitation[]
  teammember         TeamMember[]

  @@index([leaderId], map: "StudentTeam_leaderId_idx")
  @@index([filiereId], map: "StudentTeam_filiereId_idx")
  @@map("studentteam")
}

model TeamMember {
  id          String      @id @default(uuid())
  teamId      String
  studentId   String
  isLeader    Boolean     @default(false)
  joinedAt    DateTime    @default(now())
  user        User        @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentteam StudentTeam @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([teamId, studentId], map: "TeamMember_teamId_studentId_key")
  @@index([studentId], map: "TeamMember_studentId_idx")
  @@map("teammember")
}

model CompanyProfile {
  id              String  @id @default(uuid())
  userId          String  @unique(map: "CompanyProfile_userId_key")
  companyName     String
  sector          String?
  address         String?
  wilaya          String?
  contactPhone    String?
  supervisorTitle String?
  user            User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("companyprofile")
}

model Deadline {
  id           String        @id @default(uuid())
  title        String
  type         deadline_type
  dueDate      DateTime
  internshipId String?
  isGlobal     Boolean       @default(false)
  academicYear String
  createdById  String
  createdAt    DateTime      @default(now())
  user         User          @relation(fields: [createdById], references: [id], onDelete: Cascade)
  internship   Internship?   @relation(fields: [internshipId], references: [id], onDelete: Cascade)

  @@index([createdById], map: "Deadline_createdById_idx")
  @@index([internshipId], map: "Deadline_internshipId_idx")
  @@index([dueDate], map: "Deadline_dueDate_idx")
  @@map("deadline")
}

model Document {
  id                               String          @id @default(uuid())
  internshipId                     String
  uploadedById                     String
  type                             document_type
  fileName                         String
  fileUrl                          String
  fileSize                         Int
  version                          Int             @default(1)
  status                           document_status @default(UPLOADED)
  reviewComment                    String?
  reviewedById                     String?
  approvedByTeacher                Boolean         @default(false)
  approvedByCompany                Boolean         @default(false)
  reviewedByCompany                String?
  companyComment                   String?         @db.Text
  uploadedAt                       DateTime        @default(now())
  internship                       Internship      @relation(fields: [internshipId], references: [id], onDelete: Cascade)
  reviewedBy                       User?           @relation("document_reviewedByIdTouser", fields: [reviewedById], references: [id])
  uploadedBy                       User            @relation("document_uploadedByIdTouser", fields: [uploadedById], references: [id], onDelete: Cascade)

  @@index([internshipId], map: "Document_internshipId_idx")
  @@index([uploadedById], map: "Document_uploadedById_idx")
  @@index([reviewedById], map: "Document_reviewedById_idx")
  @@index([type], map: "Document_type_idx")
  @@index([status], map: "Document_status_idx")
  @@map("document")
}

model Internship {
  id                          String              @id @default(uuid())
  topicId                     String              @unique(map: "Internship_topicId_key")
  teacherId                   String
  academicYear                String
  status                      internship_status   @default(REQUESTED)
  internshipType              internship_type?
  midtermDeadline             DateTime?
  finalDeadline               DateTime?
  technicalSupervisorName     String?
  technicalSupervisorEmail    String?
  activatedAt                 DateTime?
  completedAt                 DateTime?
  startDate                   DateTime?
  endDate                     DateTime?
  teacherValidatedFinalReport Boolean             @default(false)
  teacherValidatedAt          DateTime?
  companyValidatedFinalReport Boolean             @default(false)
  companyValidatedAt          DateTime?
  archivedAt                  DateTime?
  chatArchivedAt              DateTime?
  createdAt                   DateTime            @default(now())
  updatedAt                   DateTime
  deadline                    Deadline[]
  document                    Document[]
  user                        User                @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  topic                       Topic               @relation(fields: [topicId], references: [id], onDelete: Cascade)
  internshipstudent           InternshipStudent[]
  message                     Message[]
  minipresentation            MiniPresentation[]

  @@index([teacherId], map: "Internship_teacherId_idx")
  @@index([status], map: "Internship_status_idx")
  @@index([academicYear], map: "Internship_academicYear_idx")
  @@index([internshipType], map: "Internship_internshipType_idx")
  @@map("internship")
}

model InternshipStudent {
  id           String     @id @default(uuid())
  internshipId String
  studentId    String
  isLeader     Boolean    @default(false)
  internship   Internship @relation(fields: [internshipId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([internshipId, studentId], map: "InternshipStudent_internshipId_studentId_key")
  @@index([studentId], map: "InternshipStudent_studentId_idx")
  @@index([internshipId], map: "InternshipStudent_internshipId_idx")
  @@map("internshipstudent")
}

model Message {
  id             String        @id @default(uuid())
  internshipId   String
  senderId       String
  content        String        @db.Text
  attachmentUrl  String?
  attachmentName String?
  attachmentSize Int?
  requiresAction Boolean       @default(false)
  actionType     String?
  actionStatus   String?
  actionById     String?
  sentAt         DateTime      @default(now())
  internship     Internship    @relation(fields: [internshipId], references: [id], onDelete: Cascade)
  user           User          @relation(fields: [senderId], references: [id], onDelete: Cascade)
  messageread    MessageRead[]

  @@index([internshipId], map: "Message_internshipId_idx")
  @@index([senderId], map: "Message_senderId_idx")
  @@index([actionById], map: "Message_actionById_idx")
  @@map("message")
}

model MessageRead {
  id        String   @id @default(uuid())
  messageId String
  userId    String
  readAt    DateTime @default(now())
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId], map: "MessageRead_messageId_userId_key")
  @@index([messageId], map: "MessageRead_messageId_idx")
  @@index([userId], map: "MessageRead_userId_idx")
  @@map("messageread")
}

model MiniPresentation {
  id               String                  @id @default(uuid())
  internshipId     String
  title            String
  scheduledAt      DateTime
  room             String
  timeSlot         String
  documentDeadline DateTime
  status           minipresentation_status @default(SCHEDULED)
  documentUrl      String?
  documentName     String?
  submittedAt      DateTime?
  adminComment     String?
  createdAt        DateTime                @default(now())
  internship       Internship              @relation(fields: [internshipId], references: [id], onDelete: Cascade)

  @@index([internshipId], map: "MiniPresentation_internshipId_idx")
  @@map("minipresentation")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  email     String
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "PasswordResetToken_userId_idx")
  @@map("passwordresettoken")
}

model Notification {
  id          String            @id @default(uuid())
  userId      String
  type        notification_type
  title       String
  message     String            @db.Text
  isRead      Boolean           @default(false)
  emailSent   Boolean           @default(false)
  relatedId   String?
  relatedType String?
  link        String?
  createdAt   DateTime          @default(now())
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "Notification_userId_idx")
  @@map("notification")
}

model RegistrationRequest {
  id           String                     @id @default(uuid())
  name         String
  email        String                     @unique(map: "RegistrationRequest_email_key")
  password     String
  role         registrationrequest_role
  motivation   String?                    @db.Text
  companyName  String?
  studentId    String?
  promotion    String?
  speciality   String?
  level        String?
  academicYear String?
  grade        String?
  sector       String?
  wilaya       String?
  status       registrationrequest_status @default(PENDING)
  adminComment String?
  userId       String?                    @unique(map: "RegistrationRequest_userId_key")
  createdAt    DateTime                   @default(now())
  reviewedAt   DateTime?
  user         User?                      @relation(fields: [userId], references: [id])

  @@index([userId], map: "RegistrationRequest_userId_idx")
  @@index([status], map: "RegistrationRequest_status_idx")
  @@index([name], map: "RegistrationRequest_name_idx")
  @@map("registrationrequest")
}

model StudentApplication {
  id                                      String                    @id @default(uuid())
  topicId                                 String
  status                                  studentapplication_status @default(PENDING)
  appliedAt                               DateTime                  @default(now())
  reviewedAt                              DateTime?
  message                                 String?                   @db.Text
  teamId                                  String?
  isBinome                                Boolean                   @default(false)
  leaderId                                String
  partnerId                               String?
  binomeinvitation                        binomeinvitation?
  user_studentapplication_leaderIdTouser  User                      @relation("studentapplication_leaderIdTouser", fields: [leaderId], references: [id], onDelete: Cascade)
  user_studentapplication_partnerIdTouser User?                     @relation("studentapplication_partnerIdTouser", fields: [partnerId], references: [id], onDelete: Cascade)
  studentteam                             StudentTeam?              @relation(fields: [teamId], references: [id], onDelete: Cascade)
  topic                                   Topic                     @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@index([topicId], map: "StudentApplication_topicId_idx")
  @@index([teamId], map: "StudentApplication_teamId_idx")
  @@index([status], map: "StudentApplication_status_idx")
  @@index([leaderId], map: "studentapplication_leaderId_fkey")
  @@index([partnerId], map: "studentapplication_partnerId_fkey")
  @@map("studentapplication")
}

model StudentProfile {
  id           String   @id @default(uuid())
  userId       String   @unique(map: "StudentProfile_userId_key")
  studentId    String   @unique(map: "StudentProfile_studentId_key")
  promotion    String
  speciality   String
  academicYear String
  level        String?
  filiereId    String?
  filiere      Filiere? @relation(fields: [filiereId], references: [id])
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([filiereId], map: "StudentProfile_filiereId_idx")
  @@map("studentprofile")
}

model SystemSettings {
  id        String   @id @default(uuid())
  key       String   @unique(map: "SystemSettings_key_key")
  value     String
  updatedAt DateTime

  @@map("systemsettings")
}

model Upload {
  id        String   @id @default(uuid())
  fileName  String
  fileType  String
  content   Bytes
  createdAt DateTime @default(now())

  @@map("upload")
}

/// System-wide deadline announcements visible to all users on their dashboards
model SystemDeadline {
  id        String   @id @default(uuid())
  label     String
  dueDate   DateTime
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@map("systemdeadline")
}

model TeacherApplication {
  id        String                    @id @default(uuid())
  teacherId String
  topicId   String
  message   String?                   @db.Text
  status    teacherapplication_status @default(PENDING)
  appliedAt DateTime                  @default(now())
  user      User                      @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  topic     Topic                     @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@unique([teacherId, topicId], map: "TeacherApplication_teacherId_topicId_key")
  @@index([topicId], map: "TeacherApplication_topicId_idx")
  @@map("teacherapplication")
}

model TeacherProfile {
  id          String   @id @default(uuid())
  userId      String   @unique(map: "TeacherProfile_userId_key")
  speciality  String?
  grade       String?
  maxStudents Int      @default(5)
  currentLoad Int      @default(0)
  isAvailable Boolean  @default(true)
  filiereId   String?
  filiere     Filiere? @relation(fields: [filiereId], references: [id])
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([filiereId], map: "TeacherProfile_filiereId_idx")
  @@map("teacherprofile")
}

model Topic {
  id                                 String               @id @default(uuid())
  title                              String
  description                        String               @db.Text
  requiredSkills                     String?              @db.Text
  type                               topic_type
  internshipType                     internship_type?
  status                             topic_status         @default(PENDING_ADMIN)
  maxStudents                        Int                  @default(1)
  academicYear                       String
  proposedById                       String
  assignedTeacherId                  String?
  supervisorRejectionCount           Int                  @default(0)
  resubmissionCount                  Int                  @default(0)
  maxResubmissions                   Int                  @default(3)
  rejectionReason                    String?              @db.Text
  proposedByStudent                  Boolean              @default(false)
  directAssigneeId                   String?
  companyName                        String?
  companySector                      String?
  companyAddress                     String?
  companyCity                        String?
  contactPerson                      String?
  contactEmail                       String?
  contactPhone                       String?
  supportingDocUrl                   String?
  filiereId                          String?
  targetLevels                       String?
  pendingEditData                    String?              @db.LongText
  pendingEditRequestedAt             DateTime?
  archivedAt                         DateTime?
  createdAt                          DateTime             @default(now())
  updatedAt                          DateTime
  internship                         Internship?
  studentapplication                 StudentApplication[]
  teacherapplication                 TeacherApplication[]
  assignedTeacher                    User?                @relation("topic_assignedTeacherIdTouser", fields: [assignedTeacherId], references: [id])
  directAssignee                     User?                @relation("topic_directAssigneeIdTouser", fields: [directAssigneeId], references: [id])
  filiere                            Filiere?             @relation(fields: [filiereId], references: [id])
  proposedBy                         User                 @relation("topic_proposedByIdTouser", fields: [proposedById], references: [id], onDelete: Cascade)
  validation                         Validation[]

  @@index([assignedTeacherId], map: "Topic_assignedTeacherId_idx")
  @@index([proposedById], map: "Topic_proposedById_idx")
  @@index([filiereId], map: "Topic_filiereId_idx")
  @@index([directAssigneeId], map: "topic_directAssigneeId_fkey")
  @@map("topic")
}

model User {
  id                                                    String               @id @default(uuid())
  name                                                  String
  email                                                 String               @unique(map: "User_email_key")
  password                                              String
  role                                                  user_role
  level                                                 String?
  department                                            String?
  avatarUrl                                             String?
  isActive                                              Boolean              @default(false)
  activeChatInternshipId                                String?
  activeChatPingAt                                      DateTime?
  mustChangePassword                                    Boolean              @default(true)
  createdAt                                             DateTime             @default(now())
  updatedAt                                             DateTime             @updatedAt
  adminprofile                                          AdminProfile?
  auditlog                                              AuditLog[]
  binomeinvitation                                      binomeinvitation[]
  companyprofile                                        CompanyProfile?
  deadline                                              Deadline[]
  reviewedDocuments                                     Document[]           @relation("document_reviewedByIdTouser")
  uploadedDocuments                                     Document[]           @relation("document_uploadedByIdTouser")
  internship                                            Internship[]
  internshipstudent                                     InternshipStudent[]
  message                                               Message[]
  messageread                                           MessageRead[]
  notification                                          Notification[]
  passwordresettoken                                    PasswordResetToken[]
  registrationrequest                                   RegistrationRequest?
  studentapplication_studentapplication_leaderIdTouser  StudentApplication[] @relation("studentapplication_leaderIdTouser")
  studentapplication_studentapplication_partnerIdTouser StudentApplication[] @relation("studentapplication_partnerIdTouser")
  studentprofile                                        StudentProfile?
  studentteam                                           StudentTeam[]
  teacherapplication                                    TeacherApplication[]
  teacherprofile                                        TeacherProfile?
  teaminvitation                                        TeamInvitation[]
  teammember                                            TeamMember[]
  assignedTopics                                        Topic[]              @relation("topic_assignedTeacherIdTouser")
  directAssignedTopics                                  Topic[]              @relation("topic_directAssigneeIdTouser")
  proposedTopics                                        Topic[]              @relation("topic_proposedByIdTouser")
  validation                                            Validation[]

  @@index([name], map: "User_name_idx")
  @@index([role], map: "User_role_idx")
  @@map("user")
}

model Validation {
  id          String            @id @default(uuid())
  topicId     String
  validatorId String
  step        validation_step
  status      validation_status @default(PENDING)
  comment     String?           @db.Text
  validatedAt DateTime?
  createdAt   DateTime          @default(now())
  topic       Topic             @relation(fields: [topicId], references: [id], onDelete: Cascade)
  user        User              @relation(fields: [validatorId], references: [id], onDelete: Cascade)

  @@unique([topicId, step], map: "Validation_topicId_step_key")
  @@index([topicId], map: "Validation_topicId_idx")
  @@index([validatorId], map: "Validation_validatorId_idx")
  @@map("validation")
}

model LoginAttempt {
  id           String    @id @default(uuid())
  email        String
  ip           String?
  attempts     Int       @default(1)
  lockoutUntil DateTime?
  updatedAt    DateTime  @updatedAt

  @@unique([email, ip], map: "LoginAttempt_email_ip_key")
  @@map("loginattempt")
}

model Filiere {
  id             String           @id @default(uuid())
  name           String           @unique
  code           String?
  isActive       Boolean          @default(true)
  createdAt      DateTime         @default(now())
  adminprofile   AdminProfile[]
  studentprofile StudentProfile[]
  studentteam    StudentTeam[]
  teacherprofile TeacherProfile[]
  topic          Topic[]

  @@map("filiere")
}

model binomeinvitation {
  id                   String                  @id
  studentApplicationId String                  @unique
  invitedStudentId     String
  status               binomeinvitation_status @default(PENDING)
  message              String?                 @db.Text
  respondedAt          DateTime?
  expiresAt            DateTime
  createdAt            DateTime                @default(now())
  user                 User                    @relation(fields: [invitedStudentId], references: [id], onDelete: Cascade)
  studentapplication   StudentApplication      @relation(fields: [studentApplicationId], references: [id], onDelete: Cascade)

  @@index([invitedStudentId], map: "binomeinvitation_invitedStudentId_fkey")
}

enum deadline_type {
  TOPIC_SUBMISSION
  MID_REPORT
  FINAL_REPORT
  MINI_PRESENTATION
}

enum notification_type {
  REGISTRATION_SUBMITTED
  REGISTRATION_APPROVED
  REGISTRATION_REJECTED
  TOPIC_SUBMITTED
  TOPIC_APPROVED
  TOPIC_REJECTED
  TEACHER_ASSIGNED
  TEACHER_ACCEPTED
  TEACHER_REJECTED
  TOPIC_PUBLISHED
  STUDENT_APPLIED
  APPLICATION_APPROVED
  APPLICATION_REJECTED
  BINOME_INVITATION
  BINOME_ACCEPTED
  BINOME_DECLINED
  INTERNSHIP_STARTED
  INTERNSHIP_COMPLETED
  INTERNSHIP_CANCELLED
  DOCUMENT_UPLOADED
  DOCUMENT_APPROVED
  DOCUMENT_REJECTED
  MESSAGE_RECEIVED
  MINI_PRESENTATION_SCHEDULED
  MINI_PRESENTATION_REMINDER
  DEADLINE_APPROACHING
  DEADLINE_OVERDUE
  ACCOUNT_CREATED
  PASSWORD_RESET
  ACCOUNT_MODIFIED
  REVISION_REQUESTED
  STUDENT_TOPIC_SUBMITTED
  STUDENT_TOPIC_APPROVED
  STUDENT_TOPIC_REJECTED
  COMPANY_DATES_CONFIRMED
  DEADLINE_REMINDER
  FINAL_REPORT_SUBMITTED
  FINAL_REPORT_TEACHER_VALIDATED
  FINAL_REPORT_COMPANY_VALIDATED
  FINAL_REPORT_ADMIN_CONFIRMED
}

enum teaminvitation_status {
  PENDING
  ACCEPTED
  REJECTED
  EXPIRED
}

enum document_type {
  PROGRESS_REPORT
  MID_REPORT
  FINAL_REPORT
  OTHER
}

enum registrationrequest_role {
  STUDENT
  COMPANY
  TEACHER
}

enum validation_step {
  ADMIN
  TEACHER
  COMPANY
  FINAL_ADMIN
}

enum internship_status {
  REQUESTED
  DOCUMENT_SENT
  IN_PROGRESS
  NEEDS_REVISION
  APPROVED
  FINAL_REPORT_SUBMITTED
  PENDING_ADMIN_CONFIRMATION
  COMPLETED
  CANCELLED
}

/// Internship type: PFE has mandatory midterm; NORMAL has optional midterm
enum internship_type {
  PFE
  NORMAL
}

enum studentapplication_status {
  PENDING
  ACCEPTED
  REJECTED
  CANCELLED
}

enum teacherapplication_status {
  PENDING
  ACCEPTED
  REJECTED
  CANCELLED
}

enum topic_type {
  STUDENT_PROPOSED
  COMPANY_PROPOSED
}

enum user_role {
  STUDENT
  TEACHER
  COMPANY
  ADMIN
}

enum validation_status {
  PENDING
  APPROVED
  REJECTED
}

enum topic_status {
  PENDING_ADMIN
  PENDING_TEACHER
  APPROVED
  REJECTED
  OPEN_FOR_SELECTION
  TAKEN
}

enum registrationrequest_status {
  PENDING
  APPROVED
  REJECTED
}

enum minipresentation_status {
  SCHEDULED
  DOCUMENT_SUBMITTED
  REVIEWED
  HELD
  POSTPONED
  CANCELLED
}

enum document_status {
  UPLOADED
  REVIEWED
  APPROVED
  REJECTED
}

enum binomeinvitation_status {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
}
